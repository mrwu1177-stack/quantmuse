{
  "schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS_Python_BULLDER"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolictType": "ON_FAILURE",
    "restartPolicuMaxRetries": 10,
    "startCommand": "uvicorn data_service.web.api_server:APPServer --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
 }
}